DATABASE_URL=postgresql://user:password@localhost:5432/review_dispute_agent
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev value below. Production: https://reviewshield.nimblabs.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
STRIPE_SECRET_KEY=
# Client-side key — MUST keep the NEXT_PUBLIC_ prefix (read by a Client Component)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
CRON_SECRET=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# Client (customer) session signing secret. Falls back to ADMIN_SESSION_SECRET if unset.
CLIENT_SESSION_SECRET=
# 64 hex chars (32 bytes) — encrypts OAuth tokens at rest. Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
# Transactional email via Resend. Without a key, emails are skipped (logged) — nothing breaks.
RESEND_API_KEY=
EMAIL_FROM="ReviewShield <notifications@reviewshield.nimblabs.com>"
# Operator alerts (cron failures). Without it, alerts only go to the server log.
ADMIN_ALERT_EMAIL=
